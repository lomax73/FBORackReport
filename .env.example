# Copiare in .env e valorizzare. Non committare mai .env.

DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Token per la API interna di gestione utenti (accounts/), usata dal
# Portale — raggiungibile solo da localhost (regola Nginx), vedi
# deploy/README.md. Generare con: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_TOKEN=

# Anagrafica clienti condivisa (nel Portale, app clienti/). PORTAL_API_TOKEN
# deve avere lo stesso valore di INTERNAL_API_TOKEN nel .env del Portale.
# PORTAL_INTERNAL_BASE_URL è l'URL loopback del Portale (es. https://127.0.0.1:8443
# in produzione), non l'URL pubblico. PORTAL_PUBLIC_URL è solo per il link
# "Clienti (Portale)" mostrato in sidebar.
PORTAL_INTERNAL_BASE_URL=
PORTAL_API_TOKEN=
PORTAL_PUBLIC_URL=

# In produzione: stesso schema delle altre app (vedi deploy/README.md) —
# nessun dominio configurato sul VPS, quindi IP nudo su una porta dedicata
# finché non esiste un dominio reale. Se dietro Nginx su porta non
# standard, Nginx deve inoltrare `proxy_set_header Host $http_host;`
# (non $host) altrimenti il controllo CSRF di Django fallisce in login.
